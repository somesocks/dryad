#!/usr/bin/env bash
set -euf -o pipefail

TEMP_DIR=''
FP='v2-aaaaaaaaaaaaaaaaaaaaaaaaaa'

assert_file_content_equals() { actual=$(cat "$1"); if [ "$actual" != "$2" ]; then echo "[ERROR] Fail: expected $1 to contain ($2), got ($actual)" 1>&2; return 1; fi; }

_setup() {
	TEMP_DIR=`mktemp -d 2>/dev/null || mktemp -d -t 'build-dir'`
	mkdir -p "$TEMP_DIR/dyd/roots/root-01/dyd"
	printf 'garden' > "$TEMP_DIR/dyd/type"
	printf 'root' > "$TEMP_DIR/dyd/roots/root-01/dyd/type"
	cd "$TEMP_DIR"
}

_test() {
	(cd dyd/roots/root-01 && dryad root requirement add env:dryad-test-value test-value --log-level=info)
	assert_file_content_equals "$TEMP_DIR/dyd/roots/root-01/dyd/requirements/test-value" 'env:DRYAD_TEST_VALUE'
	list_output=$(dryad root requirements list dyd/roots/root-01 --log-level=info)
	if ! printf '%s' "$list_output" | grep -Fq 'dyd/roots/root-01/dyd/requirements/test-value -> env:DRYAD_TEST_VALUE'; then
		echo "[ERROR] Fail: expected env requirement in list output" 1>&2
		printf '%s\n' "$list_output" 1>&2
		return 1
	fi
	(cd dyd/roots/root-01 && dryad root requirement add "env:dryad-test-value?fingerprint=$FP" test-value-fp --log-level=info)
	assert_file_content_equals "$TEMP_DIR/dyd/roots/root-01/dyd/requirements/test-value-fp" "env:DRYAD_TEST_VALUE?fingerprint=$FP"
	list_output=$(dryad root requirements list dyd/roots/root-01 --log-level=info)
	if ! printf '%s' "$list_output" | grep -Fq "dyd/roots/root-01/dyd/requirements/test-value-fp -> env:DRYAD_TEST_VALUE?fingerprint=$FP"; then
		echo "[ERROR] Fail: expected fingerprinted env requirement in list output" 1>&2
		printf '%s\n' "$list_output" 1>&2
		return 1
	fi
}

_teardown() { if [ -d "$TEMP_DIR" ]; then chmod -R 755 "$TEMP_DIR"; rm -rf "$TEMP_DIR"; fi; }
trap _teardown ERR EXIT
_setup
_test
