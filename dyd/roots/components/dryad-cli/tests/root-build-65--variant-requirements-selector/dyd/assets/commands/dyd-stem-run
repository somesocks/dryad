#!/usr/bin/env bash
set -euf -o pipefail

SRC_DIR=$DYD_STEM
TEMP_DIR=''

_setup() {
	TEMP_DIR=`mktemp -d 2>/dev/null || mktemp -d -t 'build-dir'`
}

_prepare() {
	cp -R "$SRC_DIR/dyd/assets/sample-garden/." "$TEMP_DIR"
	chmod -R 755 "$TEMP_DIR"
	cd "$TEMP_DIR"
}

_run_build() {
	root_name="$1"
	dryad root build "dyd/roots/$root_name" --log-level="$DYD_LOG_LEVEL" > /dev/null
}

_expect_value() {
	root_name="$1"
	descriptor="$2"
	expected="$3"
	stem="$TEMP_DIR/dyd/sprouts/$root_name/dyd/dependencies/stem~$descriptor"

	if [ ! -L "$stem" ]; then
		echo "[ERROR] Fail: expected stem dependency $root_name:stem~$descriptor" 1>&2
		find "$TEMP_DIR/dyd/sprouts/$root_name/dyd/dependencies" -mindepth 1 -maxdepth 1 -exec basename {} ';' | sort 1>&2
		return 1
	fi

	actual="$(cat "$stem/dyd/assets/value.txt")"
	if [ "$actual" != "$expected" ]; then
		echo "[ERROR] Fail: expected value '$expected' for $root_name descriptor '$descriptor', found '$actual'" 1>&2
		return 1
	fi
}

_test() {
	# 1) implicit-any: selector omits arch, so it matches both arch variants.
	_run_build root-implicit-any
	_expect_value root-implicit-any arch=amd64+os=linux linux
	_expect_value root-implicit-any arch=arm64+os=linux linux

	# 2) no-match allowed.
	_run_build root-no-match
	_expect_value root-no-match os=linux linux
	_expect_value root-no-match os=freebsd missing

	# 3) option-list selector.
	_run_build root-option-list
	_expect_value root-option-list os=linux list
	_expect_value root-option-list os=darwin list
}

_teardown() {
	if [ -d "$TEMP_DIR" ]; then
		chmod -R 755 "$TEMP_DIR"
		rm -rf "$TEMP_DIR"
	fi
}

trap _teardown ERR EXIT
_setup
_prepare
_test
