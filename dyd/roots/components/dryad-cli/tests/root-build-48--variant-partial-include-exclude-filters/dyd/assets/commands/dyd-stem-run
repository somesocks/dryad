#!/usr/bin/env bash
set -euf -o pipefail

SRC_DIR=$DYD_STEM
TEMP_DIR=''

. "$SRC_DIR/dyd/assets/assertions.sh"

_setup() {
	TEMP_DIR=`mktemp -d 2>/dev/null || mktemp -d -t 'build-dir'`
}

_prepare() {
	cp -R "$SRC_DIR/dyd/assets/sample-garden/." "$TEMP_DIR"
	chmod -R 755 "$TEMP_DIR"
	cd "$TEMP_DIR"
}

_test() {
	dryad root build "dyd/roots/root-top" --log-level="$DYD_LOG_LEVEL" > /dev/null
}

_verify() {
	deps_path="$TEMP_DIR/dyd/sprouts/root-top/dyd/dependencies"
	assert_directory_exists "$deps_path"

	if [ ! -L "$deps_path/stem~arch=amd64+os=darwin" ]; then
		echo "[ERROR] Fail: expected dependency stem~arch=amd64+os=darwin" 1>&2
		find "$deps_path" -mindepth 1 -maxdepth 1 -exec basename {} ';' | sort 1>&2
		return 1
	fi

	for dep_name in \
		"stem~arch=amd64+os=linux" \
		"stem~arch=arm64+os=darwin" \
		"stem~arch=arm64+os=linux"; do
		if [ -L "$deps_path/$dep_name" ] || [ -e "$deps_path/$dep_name" ]; then
			echo "[ERROR] Fail: unexpected dependency '$dep_name' found" 1>&2
			find "$deps_path" -mindepth 1 -maxdepth 1 -exec basename {} ';' | sort 1>&2
			return 1
		fi
	done

	dep_count=$(find "$deps_path" -mindepth 1 -maxdepth 1 \( -name 'stem' -o -name 'stem~*' \) | wc -l | tr -d ' ')
	if [ "$dep_count" != "1" ]; then
		echo "[ERROR] Fail: expected exactly 1 variant stem dependency, got $dep_count" 1>&2
		find "$deps_path" -mindepth 1 -maxdepth 1 -exec basename {} ';' | sort 1>&2
		return 1
	fi
}

_teardown() {
	if [ -d "$TEMP_DIR" ]; then
		chmod -R 755 "$TEMP_DIR"
		rm -rf "$TEMP_DIR"
	fi
}

trap _teardown ERR EXIT
_setup
_prepare
_test
_verify
