#!/usr/bin/env bash
set -euf -o pipefail

SRC_DIR=$DYD_STEM
TEMP_DIR=''

. "$SRC_DIR/dyd/assets/assertions.sh"

_setup() {
	TEMP_DIR=`mktemp -d 2>/dev/null || mktemp -d -t 'build-dir'`
}

_prepare() {
	cp -R "$SRC_DIR/dyd/assets/sample-garden/." "$TEMP_DIR"
	chmod -R 755 "$TEMP_DIR"
	cd "$TEMP_DIR"
}

_test() {
	dryad root build "dyd/roots/root-top" --log-level="$DYD_LOG_LEVEL" > /dev/null
}

_verify() {
	deps_path="$TEMP_DIR/dyd/sprouts/root-top/dyd/dependencies"
	assert_directory_exists "$deps_path"

	stem_amd64="$deps_path/stem~arch=amd64"
	stem_arm64="$deps_path/stem~arch=arm64"

	if [ ! -L "$stem_amd64" ]; then
		echo "[ERROR] Fail: expected variant stem dependency 'stem~arch=amd64'" 1>&2
		find "$deps_path" -mindepth 1 -maxdepth 1 -exec basename {} ';' | sort 1>&2
		return 1
	fi

	if [ ! -L "$stem_arm64" ]; then
		echo "[ERROR] Fail: expected variant stem dependency 'stem~arch=arm64'" 1>&2
		find "$deps_path" -mindepth 1 -maxdepth 1 -exec basename {} ';' | sort 1>&2
		return 1
	fi

	dep_for_amd64="$stem_amd64/dyd/dependencies/foo"
	if [ ! -L "$dep_for_amd64" ]; then
		echo "[ERROR] Fail: expected conditional dependency 'foo' for arch=amd64 variant" 1>&2
		find "$stem_amd64/dyd/dependencies" -mindepth 1 -maxdepth 1 -exec basename {} ';' | sort 1>&2
		return 1
	fi

	dep_for_arm64="$stem_arm64/dyd/dependencies/foo"
	if [ -e "$dep_for_arm64" ] || [ -L "$dep_for_arm64" ]; then
		echo "[ERROR] Fail: dependency 'foo' should be omitted for arch=arm64 variant" 1>&2
		find "$stem_arm64/dyd/dependencies" -mindepth 1 -maxdepth 1 -exec basename {} ';' | sort 1>&2
		return 1
	fi
}

_teardown() {
	if [ -d "$TEMP_DIR" ]; then
		chmod -R 755 "$TEMP_DIR"
		rm -rf "$TEMP_DIR"
	fi
}

trap _teardown ERR EXIT
_setup
_prepare
_test
_verify
