#!/usr/bin/env bash
set -euf -o pipefail

SRC_DIR=$DYD_STEM
TEMP_DIR=''

. "$SRC_DIR/dyd/assets/assertions.sh"

_setup() {
  TEMP_DIR=`mktemp -d 2>/dev/null || mktemp -d -t 'build-dir'`
}

_prepare() {
  cp -R "$SRC_DIR/dyd/assets/sample-garden/." "$TEMP_DIR"
  chmod -R 755 "$TEMP_DIR"
  cd "$TEMP_DIR"
}

_test() {
  fail_log="$TEMP_DIR/build-with-diagnostics.log"
  success_log="$TEMP_DIR/build-without-diagnostics.log"

  diag_cfg='json:{"version":1,"seed":1,"rules":[{"id":"inject-post-emlink","op":"os.link","key":"*","when":{"mode":"every_n","count":1},"action":{"type":"error","phase":"post","error":"EMLINK"}}]}'

  if DYD_DG="$diag_cfg" dryad root build "dyd/roots/root-01" --log-level="$DYD_LOG_LEVEL" > /dev/null 2>"$fail_log"; then
    echo "[ERROR] Fail: expected build to fail when diagnostics injects post EMLINK on os.link" 1>&2
    cat "$fail_log" 1>&2
    return 1
  fi

  if ! grep -Fq "too many links" "$fail_log" && ! grep -Fq "EMLINK" "$fail_log"; then
    echo "[ERROR] Fail: expected post-error diagnostics failure output to mention EMLINK" 1>&2
    cat "$fail_log" 1>&2
    return 1
  fi

  heap_files_path="$TEMP_DIR/dyd/heap/files"
  if [ ! -d "$heap_files_path" ]; then
    echo "[ERROR] Fail: expected post-error failed build to create heap/files side effects" 1>&2
    return 1
  fi

  cas_file_count=$(find "$heap_files_path" -maxdepth 1 -type f ! -name '.tmp-*' | wc -l | tr -d '[:space:]')
  if [ "$cas_file_count" -le 0 ]; then
    echo "[ERROR] Fail: expected at least one persisted CAS file after post-error failure" 1>&2
    find "$heap_files_path" -maxdepth 1 -type f 1>&2 || true
    return 1
  fi

  if dryad root build "dyd/roots/root-01" --log-level="$DYD_LOG_LEVEL" >"$success_log" 2>&1; then
    :
  else
    echo "[ERROR] Fail: expected build without diagnostics config to succeed" 1>&2
    cat "$success_log" 1>&2
    return 1
  fi
}

_verify() {
  assert_directory_exists "$TEMP_DIR/dyd/sprouts/root-01"
  assert_file_exists "$TEMP_DIR/dyd/sprouts/root-01/dyd/fingerprint"
}

_teardown() {
  if [ -d "$TEMP_DIR" ]; then
    chmod -R 755 "$TEMP_DIR"
    rm -rf "$TEMP_DIR"
  fi
}

trap _teardown ERR EXIT
_setup
_prepare
_test
_verify
