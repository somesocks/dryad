#!/usr/bin/env bash
set -euf -o pipefail

SRC_DIR=$DYD_STEM
TEMP_DIR=''

. "$SRC_DIR/dyd/assets/assertions.sh"

_setup() {
	TEMP_DIR=`mktemp -d 2>/dev/null || mktemp -d -t 'build-dir'`
}

_prepare() {
	cp -R "$SRC_DIR/dyd/assets/sample-garden/." "$TEMP_DIR"
	chmod -R 755 "$TEMP_DIR"
	cd "$TEMP_DIR"
}

_test() {
	dryad root build "dyd/roots/root-parent" --log-level="$DYD_LOG_LEVEL" > /dev/null
}

_verify() {
	variant_stem=''
	mapfile -t req_fp_files < <(find "$TEMP_DIR/dyd/heap/stems" -type f -path '*/dyd/requirements/*/dyd/fingerprint')

	for req_fp_file in "${req_fp_files[@]}"; do

		candidate_fingerprint=$(cat "$req_fp_file")
		candidate_stem="$TEMP_DIR/dyd/heap/stems/$candidate_fingerprint"
		if [ ! -d "$candidate_stem" ]; then
			continue
		fi
		if [ ! -f "$candidate_stem/dyd/assets/variant.txt" ]; then
			continue
		fi

		variant_stem="$candidate_stem"
		break
	done

	if [ -z "$variant_stem" ]; then
		echo "[ERROR] Fail: expected to find resolved root-variant stem from packed requirements" 1>&2
		return 1
	fi

	assert_directory_exists "$variant_stem"
	assert_file_not_exists "$variant_stem/dyd/traits/os"
	assert_directory_not_exists "$variant_stem/dyd/traits/variants"

	resolved_dep_path=''
	for dep_name in "root-variant" "root-variant,os=none"; do
		dep_path="$TEMP_DIR/dyd/sprouts/root-parent/dyd/dependencies/stem/dyd/dependencies/$dep_name"
		if [ -L "$dep_path" ] || [ -e "$dep_path" ]; then
			resolved_dep_path=$(readlink -f "$dep_path")
			break
		fi
	done
	if [ -z "$resolved_dep_path" ]; then
		echo "[ERROR] Fail: expected to find root-variant dependency under root-parent sprout stem dependencies" 1>&2
		return 1
	fi

	assert_directory_exists "$resolved_dep_path"
	assert_file_not_exists "$resolved_dep_path/dyd/traits/os"
}

_teardown() {
	if [ -d "$TEMP_DIR" ]; then
		chmod -R 755 "$TEMP_DIR"
		rm -rf "$TEMP_DIR"
	fi
}

trap _teardown ERR EXIT
_setup
_prepare
_test
_verify
