#!/usr/bin/env bash
set -euf -o pipefail

SRC_DIR=$DYD_STEM
TEMP_DIR=''

. "$SRC_DIR/dyd/assets/assertions.sh"

_setup() {
  TEMP_DIR=`mktemp -d 2>/dev/null || mktemp -d -t 'build-dir'`
}

_prepare() {
  cp -R "$SRC_DIR/dyd/assets/sample-garden/." "$TEMP_DIR"
  chmod -R 755 "$TEMP_DIR"
  cd "$TEMP_DIR"
}

_inode_of() {
  local path="$1"
  if stat -c %i "$path" >/dev/null 2>&1; then
    stat -c %i "$path"
  else
    stat -f %i "$path"
  fi
}

_diag_config() {
  local canonical_path="$1"
  local heap_files_dir="$2"
  printf 'json:{"version":1,"seed":1,"rules":[{"id":"inject-canonical-emlink","op":"os.link","key":"%s","when":{"mode":"every_x","x":1},"action":{"type":"error","error":"EMLINK"}},{"id":"delay-heap-files-temp","op":"os.create_temp","key":"%s","when":{"mode":"every_x","x":1},"action":{"type":"delay","delay_ms":200}}]}' "$canonical_path" "$heap_files_dir"
}

_wait_or_dump() {
  local pid="$1"
  local label="$2"
  local log_path="$3"
  local status=0

  if wait "$pid"; then
    return 0
  fi

  status=$?
  echo "[ERROR] Fail: concurrent build '$label' exited with status $status" 1>&2
  cat "$log_path" 1>&2
  return 1
}

_test() {
  local preseed_log="$TEMP_DIR/root-01.log"
  local root_02_log="$TEMP_DIR/root-02.log"
  local root_03_log="$TEMP_DIR/root-03.log"
  local shared_seed_path
  local canonical_path
  local diag_cfg
  local pid_02
  local pid_03

  if ! dryad root build "dyd/roots/root-01" --scope=none --log-level="$DYD_LOG_LEVEL" >"$preseed_log" 2>&1; then
    echo "[ERROR] Fail: expected preseed build for root-01 to succeed" 1>&2
    cat "$preseed_log" 1>&2
    return 1
  fi

  shared_seed_path="$TEMP_DIR/dyd/sprouts/root-01/dyd/dependencies/stem/dyd/assets/shared.txt"
  assert_file_exists "$shared_seed_path"

  canonical_path=$(find "$TEMP_DIR/dyd/heap/files" -maxdepth 1 -type f -samefile "$shared_seed_path" | head -n 1 || true)
  if [ -z "$canonical_path" ]; then
    echo "[ERROR] Fail: expected to locate canonical heap file for preseeded shared asset" 1>&2
    return 1
  fi
  printf '%s' "$canonical_path" > "$TEMP_DIR/canonical-path"

  diag_cfg=$(_diag_config "$canonical_path" "$TEMP_DIR/dyd/heap/files")

  (
    DYD_DIAG="$diag_cfg" dryad root build "dyd/roots/root-02" --scope=none --log-level="$DYD_LOG_LEVEL" >"$root_02_log" 2>&1
  ) &
  pid_02=$!

  (
    DYD_DIAG="$diag_cfg" dryad root build "dyd/roots/root-03" --scope=none --log-level="$DYD_LOG_LEVEL" >"$root_03_log" 2>&1
  ) &
  pid_03=$!

  _wait_or_dump "$pid_02" "root-02" "$root_02_log"
  _wait_or_dump "$pid_03" "root-03" "$root_03_log"
}

_verify() {
  local canonical_path
  local root_01_shared
  local root_02_shared
  local root_03_shared
  local root_01_inode
  local canonical_inode
  local root_02_inode
  local root_03_inode

  canonical_path=$(cat "$TEMP_DIR/canonical-path")
  root_01_shared="$TEMP_DIR/dyd/sprouts/root-01/dyd/dependencies/stem/dyd/assets/shared.txt"
  root_02_shared="$TEMP_DIR/dyd/sprouts/root-02/dyd/dependencies/stem/dyd/assets/shared.txt"
  root_03_shared="$TEMP_DIR/dyd/sprouts/root-03/dyd/dependencies/stem/dyd/assets/shared.txt"

  assert_file_exists "$root_01_shared"
  assert_file_exists "$root_02_shared"
  assert_file_exists "$root_03_shared"
  assert_file_content_equals "$root_02_shared" "shared-content"
  assert_file_content_equals "$root_03_shared" "shared-content"
  assert_file_content_equals "$TEMP_DIR/dyd/sprouts/root-02/dyd/dependencies/stem/dyd/assets/unique.txt" "unique-root-02"
  assert_file_content_equals "$TEMP_DIR/dyd/sprouts/root-03/dyd/dependencies/stem/dyd/assets/unique.txt" "unique-root-03"
  assert_file_exists "$canonical_path"

  if find "$TEMP_DIR/dyd/heap/files" -maxdepth 1 -type f -name "$(basename "$canonical_path").replica.*" | grep -q .; then
    echo "[ERROR] Fail: expected canonical replacement instead of side-by-side heap replicas" 1>&2
    find "$TEMP_DIR/dyd/heap/files" -maxdepth 1 -type f -name "$(basename "$canonical_path").replica.*" 1>&2
    return 1
  fi

  root_01_inode="$(_inode_of "$root_01_shared")"
  canonical_inode="$(_inode_of "$canonical_path")"
  root_02_inode="$(_inode_of "$root_02_shared")"
  root_03_inode="$(_inode_of "$root_03_shared")"

  if [ "$canonical_inode" = "$root_01_inode" ]; then
    echo "[ERROR] Fail: expected canonical heap path to be refreshed away from the preseeded inode" 1>&2
    echo "canonical_inode=$canonical_inode root_01_inode=$root_01_inode" 1>&2
    return 1
  fi

  if [ "$root_02_inode" = "$root_01_inode" ] || [ "$root_03_inode" = "$root_01_inode" ]; then
    echo "[ERROR] Fail: expected concurrent builds to stop using the preseeded saturated inode" 1>&2
    echo "root_01_inode=$root_01_inode root_02_inode=$root_02_inode root_03_inode=$root_03_inode" 1>&2
    return 1
  fi

  if [ "$canonical_inode" != "$root_02_inode" ] && [ "$canonical_inode" != "$root_03_inode" ]; then
    echo "[ERROR] Fail: expected the refreshed canonical heap path to match one concurrent build output inode" 1>&2
    echo "canonical_inode=$canonical_inode root_02_inode=$root_02_inode root_03_inode=$root_03_inode" 1>&2
    return 1
  fi

  if find "$TEMP_DIR/dyd/heap/files" -maxdepth 1 -type f -name '.tmp-*' | grep -q .; then
    echo "[ERROR] Fail: expected no temp files left in heap/files after concurrent rollover" 1>&2
    find "$TEMP_DIR/dyd/heap/files" -maxdepth 1 -type f -name '.tmp-*' 1>&2
    return 1
  fi
}

_teardown() {
  if [ -d "$TEMP_DIR" ]; then
    chmod -R 755 "$TEMP_DIR"
    rm -rf "$TEMP_DIR"
  fi
}

trap _teardown ERR EXIT
_setup
_prepare
_test
_verify
