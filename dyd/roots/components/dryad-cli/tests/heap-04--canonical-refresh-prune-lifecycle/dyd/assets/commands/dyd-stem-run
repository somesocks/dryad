#!/usr/bin/env bash
set -euf -o pipefail

SRC_DIR=$DYD_STEM
TEMP_DIR=''

. "$SRC_DIR/dyd/assets/assertions.sh"

_setup() {
  TEMP_DIR=`mktemp -d 2>/dev/null || mktemp -d -t 'build-dir'`
}

_prepare() {
  cp -R "$SRC_DIR/dyd/assets/sample-garden/." "$TEMP_DIR"
  chmod -R 755 "$TEMP_DIR"
  cd "$TEMP_DIR"
}

_realpath_dir() {
  (
    cd "$1"
    pwd -P
  )
}

_inode_of() {
  local path="$1"
  if stat -c %i "$path" >/dev/null 2>&1; then
    stat -c %i "$path"
  else
    stat -f %i "$path"
  fi
}

_test() {
  local first_build_log="$TEMP_DIR/build-first.log"
  local second_build_log="$TEMP_DIR/build-second.log"
  local third_build_log="$TEMP_DIR/build-third.log"
  local shared_path
  local unique_path
  local old_stem_path
  local old_stem_fingerprint
  local old_inode
  local canonical_path
  local diag_cfg

  cat > "$TEMP_DIR/dyd/roots/root-01/dyd/assets/test-file-01" <<'EOF'
shared-content
EOF
  cat > "$TEMP_DIR/dyd/roots/root-01/dyd/assets/test-dir-01/test-file-02" <<'EOF'
other-content
EOF
  cat > "$TEMP_DIR/dyd/roots/root-01/dyd/assets/unique.txt" <<'EOF'
unique-v1
EOF

  if ! dryad root build "dyd/roots/root-01" --scope=none --log-level="$DYD_LOG_LEVEL" >"$first_build_log" 2>&1; then
    echo "[ERROR] Fail: expected initial build to succeed" 1>&2
    cat "$first_build_log" 1>&2
    return 1
  fi

  shared_path="$TEMP_DIR/dyd/sprouts/root-01/dyd/dependencies/stem/dyd/assets/test-file-01"
  unique_path="$TEMP_DIR/dyd/sprouts/root-01/dyd/dependencies/stem/dyd/assets/unique.txt"
  old_stem_path="$(_realpath_dir "$TEMP_DIR/dyd/sprouts/root-01/dyd/dependencies/stem")"
  old_stem_fingerprint=$(cat "$old_stem_path/dyd/fingerprint")
  old_inode="$(_inode_of "$shared_path")"
  canonical_path=$(find "$TEMP_DIR/dyd/heap/files" -maxdepth 1 -type f -samefile "$shared_path" | head -n 1 || true)

  if [ -z "$canonical_path" ]; then
    echo "[ERROR] Fail: expected to locate canonical heap file for the shared asset" 1>&2
    return 1
  fi

  printf '%s' "$old_stem_path" > "$TEMP_DIR/old-stem-path"
  printf '%s' "$old_stem_fingerprint" > "$TEMP_DIR/old-stem-fingerprint"
  printf '%s' "$old_inode" > "$TEMP_DIR/old-inode"
  printf '%s' "$canonical_path" > "$TEMP_DIR/canonical-path"

  find "$TEMP_DIR/dyd" \
    \( -type l -o -type f -o -type d \) \
    -exec touch -h -d "2000-01-01 00:00:00" {} +

  cat > "$TEMP_DIR/dyd/roots/root-01/dyd/assets/unique.txt" <<'EOF'
unique-v2
EOF

  diag_cfg=$(printf 'json:{"version":1,"seed":1,"rules":[{"id":"inject-canonical-emlink","op":"os.link","key":"%s","when":{"mode":"every_x","x":1},"action":{"type":"error","error":"EMLINK"}}]}' "$canonical_path")
  if ! DYD_DIAG="$diag_cfg" dryad root build "dyd/roots/root-01" --scope=none --log-level="$DYD_LOG_LEVEL" >"$second_build_log" 2>&1; then
    echo "[ERROR] Fail: expected second build to recover from a forced canonical EMLINK" 1>&2
    cat "$second_build_log" 1>&2
    return 1
  fi

  if ! dryad garden prune --log-level="$DYD_LOG_LEVEL" >"$TEMP_DIR/prune.log" 2>&1; then
    echo "[ERROR] Fail: expected garden prune to succeed after canonical refresh" 1>&2
    cat "$TEMP_DIR/prune.log" 1>&2
    return 1
  fi

  if ! dryad root build "dyd/roots/root-01" --scope=none --log-level="$DYD_LOG_LEVEL" >"$third_build_log" 2>&1; then
    echo "[ERROR] Fail: expected build after prune to succeed" 1>&2
    cat "$third_build_log" 1>&2
    return 1
  fi
}

_verify() {
  local canonical_path
  local old_stem_path
  local old_stem_fingerprint
  local old_inode
  local new_stem_path
  local new_shared_path
  local new_unique_path
  local canonical_inode
  local new_inode

  canonical_path=$(cat "$TEMP_DIR/canonical-path")
  old_stem_path=$(cat "$TEMP_DIR/old-stem-path")
  old_stem_fingerprint=$(cat "$TEMP_DIR/old-stem-fingerprint")
  old_inode=$(cat "$TEMP_DIR/old-inode")
  new_stem_path="$(_realpath_dir "$TEMP_DIR/dyd/sprouts/root-01/dyd/dependencies/stem")"
  new_shared_path="$TEMP_DIR/dyd/sprouts/root-01/dyd/dependencies/stem/dyd/assets/test-file-01"
  new_unique_path="$TEMP_DIR/dyd/sprouts/root-01/dyd/dependencies/stem/dyd/assets/unique.txt"

  assert_directory_exists "$TEMP_DIR/dyd/sprouts/root-01"
  assert_file_exists "$TEMP_DIR/dyd/sprouts/root-01/dyd/fingerprint"
  assert_file_exists "$canonical_path"
  assert_file_exists "$new_shared_path"
  assert_file_exists "$new_unique_path"
  assert_file_content_equals "$new_shared_path" "shared-content"
  assert_file_content_equals "$new_unique_path" "unique-v2"

  canonical_inode="$(_inode_of "$canonical_path")"
  new_inode="$(_inode_of "$new_shared_path")"

  if [ "$new_stem_path" = "$old_stem_path" ]; then
    echo "[ERROR] Fail: expected the rebuilt root to move to a new stem path" 1>&2
    echo "old_stem_path=$old_stem_path new_stem_path=$new_stem_path" 1>&2
    return 1
  fi

  if [ -e "$old_stem_path" ]; then
    echo "[ERROR] Fail: expected prune to remove the unreachable old stem" 1>&2
    echo "old_stem_path=$old_stem_path" 1>&2
    return 1
  fi

  if [ -e "$TEMP_DIR/dyd/heap/stems/$old_stem_fingerprint" ]; then
    echo "[ERROR] Fail: expected prune to remove the old heap stem directory" 1>&2
    echo "old_stem_fingerprint=$old_stem_fingerprint" 1>&2
    return 1
  fi

  if [ "$canonical_inode" = "$old_inode" ]; then
    echo "[ERROR] Fail: expected the canonical heap path to stay refreshed after prune" 1>&2
    echo "canonical_inode=$canonical_inode old_inode=$old_inode" 1>&2
    return 1
  fi

  if [ "$new_inode" = "$old_inode" ]; then
    echo "[ERROR] Fail: expected the rebuilt stem to stop using the old saturated inode" 1>&2
    echo "new_inode=$new_inode old_inode=$old_inode" 1>&2
    return 1
  fi

  if [ "$canonical_inode" != "$new_inode" ]; then
    echo "[ERROR] Fail: expected the refreshed canonical heap file to match the rebuilt stem inode" 1>&2
    echo "canonical_inode=$canonical_inode new_inode=$new_inode" 1>&2
    return 1
  fi
}

_teardown() {
  if [ -d "$TEMP_DIR" ]; then
    chmod -R 755 "$TEMP_DIR"
    rm -rf "$TEMP_DIR"
  fi
}

trap _teardown ERR EXIT
_setup
_prepare
_test
_verify
