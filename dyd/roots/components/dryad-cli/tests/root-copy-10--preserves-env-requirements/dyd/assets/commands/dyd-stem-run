#!/usr/bin/env bash
set -euf -o pipefail

TEMP_DIR=''

assert_file_content_equals() { actual=$(cat "$1"); if [ "$actual" != "$2" ]; then echo "[ERROR] Fail: expected $1 to contain ($2), got ($actual)" 1>&2; return 1; fi; }

_setup() {
	TEMP_DIR=`mktemp -d 2>/dev/null || mktemp -d -t 'build-dir'`
	mkdir -p "$TEMP_DIR/dyd/roots"
	printf 'garden' > "$TEMP_DIR/dyd/type"
	cd "$TEMP_DIR"
}

_create_root() {
	root_name="$1"
	mkdir -p "dyd/roots/$root_name/dyd/commands" "dyd/roots/$root_name/dyd/requirements"
	printf 'root' > "dyd/roots/$root_name/dyd/type"
	cat > "dyd/roots/$root_name/dyd/commands/dyd-root-build" <<'EOF'
#!/usr/bin/env sh
set -eu
mkdir -p "$DYD_BUILD/dyd/assets"
printf '%s' "${TOKEN:-none}" > "$DYD_BUILD/dyd/assets/value.txt"
EOF
	chmod +x "dyd/roots/$root_name/dyd/commands/dyd-root-build"
}

_test() {
	_create_root root-source
	printf 'env:DRYAD_TEST_COPY_TOKEN' > dyd/roots/root-source/dyd/requirements/token
	dryad root copy dyd/roots/root-source dyd/roots/root-copy --log-level=info > /dev/null 2>&1
	assert_file_content_equals "$TEMP_DIR/dyd/roots/root-copy/dyd/requirements/token" 'env:DRYAD_TEST_COPY_TOKEN'
	DRYAD_TEST_COPY_TOKEN='copy-value' dryad root build dyd/roots/root-copy --log-level=info > /dev/null 2>&1
	assert_file_content_equals "$TEMP_DIR/dyd/sprouts/root-copy/dyd/dependencies/stem/dyd/assets/value.txt" 'copy-value'
}

_teardown() { if [ -d "$TEMP_DIR" ]; then chmod -R 755 "$TEMP_DIR"; rm -rf "$TEMP_DIR"; fi; }
trap _teardown ERR EXIT
_setup
_test
