#!/usr/bin/env bash
set -euf -o pipefail

SRC_DIR=$DYD_STEM
TEMP_DIR=''

. "$SRC_DIR/dyd/assets/assertions.sh"

_setup() {
	TEMP_DIR=`mktemp -d 2>/dev/null || mktemp -d -t 'build-dir'`
}

_prepare() {
	cp -R "$SRC_DIR/dyd/assets/sample-garden/." "$TEMP_DIR"
	chmod -R 755 "$TEMP_DIR"
	cd "$TEMP_DIR"
}

_test() {
	dryad root build "dyd/roots/root-top" --log-level="$DYD_LOG_LEVEL" > /dev/null
	dryad sprout run "dyd/sprouts/root-top" --variant="arch=any,os=linux" --log-level="$DYD_LOG_LEVEL" > /dev/null
}

_verify() {
	out_dir="$TEMP_DIR/dyd/heap/sprout-run-08--variant-any-runs-set"
	assert_directory_exists "$out_dir"
	assert_file_content_equals "$out_dir/amd64-linux" "ok"
	assert_file_content_equals "$out_dir/arm64-linux" "ok"

	if [ -f "$out_dir/amd64-darwin" ] || [ -f "$out_dir/arm64-darwin" ]; then
		echo "[ERROR] Fail: darwin variants should not run for selector arch=any,os=linux" 1>&2
		ls -1 "$out_dir" 1>&2
		return 1
	fi
}

_teardown() {
	if [ -d "$TEMP_DIR" ]; then
		chmod -R 755 "$TEMP_DIR"
		rm -rf "$TEMP_DIR"
	fi
}

trap _teardown ERR EXIT
_setup
_prepare
_test
_verify
