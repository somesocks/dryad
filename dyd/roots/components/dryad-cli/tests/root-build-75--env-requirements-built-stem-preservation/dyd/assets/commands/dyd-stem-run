#!/usr/bin/env bash
set -euf -o pipefail

TEMP_DIR=''

assert_file_content_equals() {
	file="$1"
	expected="$2"
	if [ ! -f "$file" ]; then echo "[ERROR] Fail: file '$file' missing" 1>&2; return 1; fi
	actual=$(cat "$file")
	if [ "$actual" != "$expected" ]; then echo "[ERROR] Fail: expected ($expected), got ($actual) for $file" 1>&2; return 1; fi
}

_setup() {
	TEMP_DIR=`mktemp -d 2>/dev/null || mktemp -d -t 'build-dir'`
	mkdir -p "$TEMP_DIR/dyd/roots"
	printf 'garden' > "$TEMP_DIR/dyd/type"
	cd "$TEMP_DIR"
}

_create_root() {
	root_name="$1"
	req_name="$2"
	req_target="$3"
	copy_source="$4"
	mkdir -p "dyd/roots/$root_name/dyd/commands" "dyd/roots/$root_name/dyd/requirements"
	printf 'root' > "dyd/roots/$root_name/dyd/type"
	if [ "$copy_source" = 'yes' ]; then
		printf '%s' "$req_target" > "dyd/roots/$root_name/dyd/requirements/$req_name"
	fi
	cat > "dyd/roots/$root_name/dyd/commands/dyd-root-build" <<EOF
#!/usr/bin/env sh
set -eu
mkdir -p "\$DYD_BUILD/dyd/requirements"
if [ '$copy_source' = 'yes' ]; then
  cp -R "\$DYD_STEM/dyd/requirements/." "\$DYD_BUILD/dyd/requirements/"
else
  printf '%s' '$req_target' > "\$DYD_BUILD/dyd/requirements/$req_name"
fi
cat > "\$DYD_BUILD/dyd/commands/dyd-stem-run" <<'RUNEOF'
#!/usr/bin/env sh
set -eu
value=\${BUILD_VALUE:-\${RUNTIME_VALUE:-}}
mkdir -p "\$DYD_GARDEN/dyd/heap/env-requirements-03"
printf '%s' "\$value" > "\$DYD_GARDEN/dyd/heap/env-requirements-03/$root_name"
RUNEOF
chmod +x "\$DYD_BUILD/dyd/commands/dyd-stem-run"
EOF
	chmod +x "dyd/roots/$root_name/dyd/commands/dyd-root-build"
}

_find_materialized_requirement() {
	name="$1"
	prefix="$2"
	while IFS= read -r f; do
		content=$(cat "$f")
		case "$content" in $prefix*) printf '%s' "$content"; return 0 ;; esac
	done < <(find "$TEMP_DIR/dyd/heap/stems" -type f -path "*/dyd/requirements/$name" 2>/dev/null)
	return 1
}

_expect_run_fails() {
	root_name="$1"
	shift
	set +e
	output=$("$@" dryad sprout run "dyd/sprouts/$root_name" --log-level=info 2>&1)
	status=$?
	set -e
	if [ "$status" -eq 0 ]; then
		echo "[ERROR] Fail: expected sprout run of $root_name to fail" 1>&2
		printf '%s\n' "$output" 1>&2
		return 1
	fi
}

_test() {
	_create_root root-runtime runtime-value env:DRYAD_TEST_RUNTIME_VALUE no
	dryad root build dyd/roots/root-runtime --log-level=info > /dev/null 2>&1
	assert_file_content_equals "$TEMP_DIR/dyd/sprouts/root-runtime/dyd/dependencies/stem/dyd/requirements/RUNTIME_VALUE" 'env:DRYAD_TEST_RUNTIME_VALUE'

	_create_root root-helper build-value env:DRYAD_TEST_COPY_VALUE yes
	DRYAD_TEST_COPY_VALUE='copy-value' dryad root build dyd/roots/root-helper --log-level=info > /dev/null 2>&1
	fp_req=$(_find_materialized_requirement BUILD_VALUE 'env:DRYAD_TEST_COPY_VALUE?fingerprint=')
	_create_root root-runtime-fp runtime-value "$fp_req" no
	dryad root build dyd/roots/root-runtime-fp --log-level=info > /dev/null 2>&1
	assert_file_content_equals "$TEMP_DIR/dyd/sprouts/root-runtime-fp/dyd/dependencies/stem/dyd/requirements/RUNTIME_VALUE" "$fp_req"

	_create_root root-copy build-value env:DRYAD_TEST_COPY_VALUE yes
	DRYAD_TEST_COPY_VALUE='copy-value' dryad root build dyd/roots/root-copy --log-level=info > /dev/null 2>&1
	copied_req=$(cat "$TEMP_DIR/dyd/sprouts/root-copy/dyd/dependencies/stem/dyd/requirements/BUILD_VALUE")
	case "$copied_req" in env:DRYAD_TEST_COPY_VALUE?fingerprint=*) ;; *) echo "[ERROR] Fail: expected copied build env requirement to be fingerprinted" 1>&2; return 1 ;; esac
	DRYAD_TEST_COPY_VALUE='copy-value' dryad sprout run dyd/sprouts/root-copy --log-level=info > /dev/null 2>&1
	assert_file_content_equals "$TEMP_DIR/dyd/heap/env-requirements-03/root-copy" 'copy-value'
	_expect_run_fails root-copy env DRYAD_TEST_COPY_VALUE='changed'
}

_teardown() { if [ -d "$TEMP_DIR" ]; then chmod -R 755 "$TEMP_DIR"; rm -rf "$TEMP_DIR"; fi; }
trap _teardown ERR EXIT
_setup
_test
