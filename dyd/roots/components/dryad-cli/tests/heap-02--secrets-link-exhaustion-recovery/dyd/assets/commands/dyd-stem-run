#!/usr/bin/env bash
set -euf -o pipefail

SRC_DIR=$DYD_STEM
TEMP_DIR=''

. "$SRC_DIR/dyd/assets/assertions.sh"

_setup() {
  TEMP_DIR=`mktemp -d 2>/dev/null || mktemp -d -t 'build-dir'`
}

_prepare() {
  cp -R "$SRC_DIR/dyd/assets/sample-garden/." "$TEMP_DIR"
  chmod -R 755 "$TEMP_DIR"
  cd "$TEMP_DIR"
}

_realpath_dir() {
  (
    cd "$1"
    pwd -P
  )
}

_inode_of() {
  local path="$1"
  if stat -c %i "$path" >/dev/null 2>&1; then
    stat -c %i "$path"
  else
    stat -f %i "$path"
  fi
}

_test() {
  local first_build_log="$TEMP_DIR/build-first.log"
  local second_build_log="$TEMP_DIR/build-second.log"
  local third_build_log="$TEMP_DIR/build-third.log"
  local fourth_build_log="$TEMP_DIR/build-fourth.log"
  local secret_path
  local old_stem_path
  local old_stem_fingerprint
  local old_inode
  local middle_stem_path
  local middle_stem_fingerprint
  local middle_inode
  local canonical_path
  local diag_cfg

  cat > "$TEMP_DIR/dyd/roots/root-01/dyd/secrets/test-secret-01" <<'EOF'
shared-secret
EOF
  cat > "$TEMP_DIR/dyd/roots/root-01/dyd/secrets/test-dir-01/test-secret-02" <<'EOF'
shared-secret
EOF
  cat > "$TEMP_DIR/dyd/roots/root-01/dyd/secrets/unique-secret.txt" <<'EOF'
unique-secret-v1
EOF

  if ! dryad root build "dyd/roots/root-01" --scope=none --log-level="$DYD_LOG_LEVEL" >"$first_build_log" 2>&1; then
    echo "[ERROR] Fail: expected initial secret build to succeed" 1>&2
    cat "$first_build_log" 1>&2
    return 1
  fi

  secret_path="$TEMP_DIR/dyd/sprouts/root-01/dyd/dependencies/stem/dyd/secrets/test-secret-01"
  old_stem_path="$(_realpath_dir "$TEMP_DIR/dyd/sprouts/root-01/dyd/dependencies/stem")"
  old_stem_fingerprint=$(cat "$old_stem_path/dyd/fingerprint")
  old_inode="$(_inode_of "$secret_path")"
  canonical_path=$(find "$TEMP_DIR/dyd/heap/secrets" -maxdepth 1 -type f -samefile "$secret_path" | head -n 1 || true)

  if [ -z "$canonical_path" ]; then
    echo "[ERROR] Fail: expected to locate canonical heap secret for the shared secret" 1>&2
    return 1
  fi

  printf '%s' "$old_stem_path" > "$TEMP_DIR/old-stem-path"
  printf '%s' "$old_stem_fingerprint" > "$TEMP_DIR/old-stem-fingerprint"
  printf '%s' "$old_inode" > "$TEMP_DIR/old-inode"
  printf '%s' "$canonical_path" > "$TEMP_DIR/canonical-path"

  find "$TEMP_DIR/dyd" \
    \( -type l -o -type f -o -type d \) \
    -exec touch -h -d "2000-01-01 00:00:00" {} +

  cat > "$TEMP_DIR/dyd/roots/root-01/dyd/secrets/unique-secret.txt" <<'EOF'
unique-secret-v2
EOF

  diag_cfg=$(printf 'json:{"version":1,"seed":1,"rules":[{"id":"inject-canonical-emlink","op":"os.link","key":"%s","when":{"mode":"every_x","x":1},"action":{"type":"error","error":"EMLINK"}}]}' "$canonical_path")
  if ! DYD_DIAG="$diag_cfg" dryad root build "dyd/roots/root-01" --scope=none --log-level="$DYD_LOG_LEVEL" >"$second_build_log" 2>&1; then
    echo "[ERROR] Fail: expected second secret build to recover from a forced canonical EMLINK" 1>&2
    cat "$second_build_log" 1>&2
    return 1
  fi

  middle_stem_path="$(_realpath_dir "$TEMP_DIR/dyd/sprouts/root-01/dyd/dependencies/stem")"
  middle_stem_fingerprint=$(cat "$middle_stem_path/dyd/fingerprint")
  middle_inode="$(_inode_of "$canonical_path")"

  if [ "$middle_stem_path" = "$old_stem_path" ]; then
    echo "[ERROR] Fail: expected the first refreshed secret build to move to a new stem path" 1>&2
    echo "old_stem_path=$old_stem_path middle_stem_path=$middle_stem_path" 1>&2
    return 1
  fi

  if [ "$middle_inode" = "$old_inode" ]; then
    echo "[ERROR] Fail: expected the canonical heap secret to refresh on the first rebuilt generation" 1>&2
    echo "middle_inode=$middle_inode old_inode=$old_inode" 1>&2
    return 1
  fi

  printf '%s' "$middle_stem_path" > "$TEMP_DIR/middle-stem-path"
  printf '%s' "$middle_stem_fingerprint" > "$TEMP_DIR/middle-stem-fingerprint"
  printf '%s' "$middle_inode" > "$TEMP_DIR/middle-inode"

  find "$TEMP_DIR/dyd" \
    \( -type l -o -type f -o -type d \) \
    -exec touch -h -d "2000-01-01 00:00:00" {} +

  cat > "$TEMP_DIR/dyd/roots/root-01/dyd/secrets/unique-secret.txt" <<'EOF'
unique-secret-v3
EOF

  if ! DYD_DIAG="$diag_cfg" dryad root build "dyd/roots/root-01" --scope=none --log-level="$DYD_LOG_LEVEL" >"$third_build_log" 2>&1; then
    echo "[ERROR] Fail: expected third secret build to recover from a second forced canonical EMLINK" 1>&2
    cat "$third_build_log" 1>&2
    return 1
  fi

  if ! dryad garden prune --log-level="$DYD_LOG_LEVEL" >"$TEMP_DIR/prune.log" 2>&1; then
    echo "[ERROR] Fail: expected garden prune to succeed after repeated secret canonical refreshes" 1>&2
    cat "$TEMP_DIR/prune.log" 1>&2
    return 1
  fi

  if ! dryad root build "dyd/roots/root-01" --scope=none --log-level="$DYD_LOG_LEVEL" >"$fourth_build_log" 2>&1; then
    echo "[ERROR] Fail: expected secret build after prune to succeed" 1>&2
    cat "$fourth_build_log" 1>&2
    return 1
  fi
}

_verify() {
  local canonical_path
  local old_stem_path
  local old_stem_fingerprint
  local old_inode
  local middle_stem_path
  local middle_stem_fingerprint
  local middle_inode
  local new_stem_path
  local new_secret_path
  local new_secret_path_2
  local new_unique_path
  local canonical_inode
  local new_inode_1
  local new_inode_2

  canonical_path=$(cat "$TEMP_DIR/canonical-path")
  old_stem_path=$(cat "$TEMP_DIR/old-stem-path")
  old_stem_fingerprint=$(cat "$TEMP_DIR/old-stem-fingerprint")
  old_inode=$(cat "$TEMP_DIR/old-inode")
  middle_stem_path=$(cat "$TEMP_DIR/middle-stem-path")
  middle_stem_fingerprint=$(cat "$TEMP_DIR/middle-stem-fingerprint")
  middle_inode=$(cat "$TEMP_DIR/middle-inode")
  new_stem_path="$(_realpath_dir "$TEMP_DIR/dyd/sprouts/root-01/dyd/dependencies/stem")"
  new_secret_path="$TEMP_DIR/dyd/sprouts/root-01/dyd/dependencies/stem/dyd/secrets/test-secret-01"
  new_secret_path_2="$TEMP_DIR/dyd/sprouts/root-01/dyd/dependencies/stem/dyd/secrets/test-dir-01/test-secret-02"
  new_unique_path="$TEMP_DIR/dyd/sprouts/root-01/dyd/dependencies/stem/dyd/secrets/unique-secret.txt"

  assert_directory_exists "$TEMP_DIR/dyd/sprouts/root-01"
  assert_file_exists "$TEMP_DIR/dyd/sprouts/root-01/dyd/fingerprint"
  assert_file_exists "$canonical_path"
  assert_file_exists "$new_secret_path"
  assert_file_exists "$new_secret_path_2"
  assert_file_exists "$new_unique_path"
  assert_file_content_equals "$new_secret_path" "shared-secret"
  assert_file_content_equals "$new_secret_path_2" "shared-secret"
  assert_file_content_equals "$new_unique_path" "unique-secret-v3"

  canonical_inode="$(_inode_of "$canonical_path")"
  new_inode_1="$(_inode_of "$new_secret_path")"
  new_inode_2="$(_inode_of "$new_secret_path_2")"

  if [ "$new_stem_path" = "$old_stem_path" ] || [ "$new_stem_path" = "$middle_stem_path" ]; then
    echo "[ERROR] Fail: expected the second refreshed secret build to move to a third stem path" 1>&2
    echo "old_stem_path=$old_stem_path middle_stem_path=$middle_stem_path new_stem_path=$new_stem_path" 1>&2
    return 1
  fi

  if [ -e "$old_stem_path" ]; then
    echo "[ERROR] Fail: expected prune to remove the unreachable original secret stem" 1>&2
    echo "old_stem_path=$old_stem_path" 1>&2
    return 1
  fi

  if [ -e "$TEMP_DIR/dyd/heap/stems/$old_stem_fingerprint" ]; then
    echo "[ERROR] Fail: expected prune to remove the original heap stem directory for secrets" 1>&2
    echo "old_stem_fingerprint=$old_stem_fingerprint" 1>&2
    return 1
  fi

  if [ -e "$middle_stem_path" ]; then
    echo "[ERROR] Fail: expected prune to remove the first refreshed secret stem once a newer generation existed" 1>&2
    echo "middle_stem_path=$middle_stem_path" 1>&2
    return 1
  fi

  if [ -e "$TEMP_DIR/dyd/heap/stems/$middle_stem_fingerprint" ]; then
    echo "[ERROR] Fail: expected prune to remove the middle heap stem directory for secrets" 1>&2
    echo "middle_stem_fingerprint=$middle_stem_fingerprint" 1>&2
    return 1
  fi

  if [ "$canonical_inode" = "$old_inode" ]; then
    echo "[ERROR] Fail: expected the canonical heap secret to stay refreshed after prune" 1>&2
    echo "canonical_inode=$canonical_inode old_inode=$old_inode" 1>&2
    return 1
  fi

  if [ "$canonical_inode" = "$middle_inode" ]; then
    echo "[ERROR] Fail: expected the canonical heap secret to refresh again for the second generation" 1>&2
    echo "canonical_inode=$canonical_inode middle_inode=$middle_inode" 1>&2
    return 1
  fi

  if [ "$canonical_inode" = "$old_inode" ] || [ "$canonical_inode" = "$middle_inode" ]; then
    echo "[ERROR] Fail: expected the canonical heap secret to advance past both earlier generations" 1>&2
    echo "canonical_inode=$canonical_inode old_inode=$old_inode middle_inode=$middle_inode" 1>&2
    return 1
  fi

  if [ "$canonical_inode" != "$new_inode_1" ] && [ "$canonical_inode" != "$new_inode_2" ]; then
    echo "[ERROR] Fail: expected the rebuilt secret stem to include the final canonical heap inode" 1>&2
    echo "canonical_inode=$canonical_inode new_inode_1=$new_inode_1 new_inode_2=$new_inode_2" 1>&2
    return 1
  fi

  if find "$TEMP_DIR/dyd/heap/secrets" -maxdepth 1 -type f -name '.tmp-*' | grep -q .; then
    echo "[ERROR] Fail: expected no temp files left in heap/secrets after repeated refreshes" 1>&2
    find "$TEMP_DIR/dyd/heap/secrets" -maxdepth 1 -type f -name '.tmp-*' 1>&2
    return 1
  fi
}

_teardown() {
  if [ -d "$TEMP_DIR" ]; then
    chmod -R 755 "$TEMP_DIR"
    rm -rf "$TEMP_DIR"
  fi
}

trap _teardown ERR EXIT
_setup
_prepare
_test
_verify
