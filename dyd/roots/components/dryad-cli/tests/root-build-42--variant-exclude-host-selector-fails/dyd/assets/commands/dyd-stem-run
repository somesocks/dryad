#!/usr/bin/env bash
set -euf -o pipefail

SRC_DIR=$DYD_STEM
TEMP_DIR=''

. "$SRC_DIR/dyd/assets/assertions.sh"

_setup() {
	TEMP_DIR=`mktemp -d 2>/dev/null || mktemp -d -t 'build-dir'`
}

_prepare() {
	cp -R "$SRC_DIR/dyd/assets/sample-garden/." "$TEMP_DIR"
	chmod -R 755 "$TEMP_DIR"
	cd "$TEMP_DIR"
}

_test() {
	log_path="$TEMP_DIR/build.log"
	if dryad root build "dyd/roots/root-top" --log-level="$DYD_LOG_LEVEL" >"$log_path" 2>&1; then
		echo "[ERROR] Fail: expected build to fail for host selector in variants/_exclude" 1>&2
		cat "$log_path" 1>&2
		return 1
	fi

	if ! grep -Fq "host option is not supported for excluded variant selectors" "$log_path"; then
		echo "[ERROR] Fail: expected host selector failure message in root build output" 1>&2
		cat "$log_path" 1>&2
		return 1
	fi
}

_teardown() {
	if [ -d "$TEMP_DIR" ]; then
		chmod -R 755 "$TEMP_DIR"
		rm -rf "$TEMP_DIR"
	fi
}

trap _teardown ERR EXIT
_setup
_prepare
_test
