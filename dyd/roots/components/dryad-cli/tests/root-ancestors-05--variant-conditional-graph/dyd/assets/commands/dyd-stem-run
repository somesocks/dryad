#!/usr/bin/env bash

set -euf -o pipefail

SRC_DIR=$DYD_STEM
TEMP_DIR=''

. "$SRC_DIR/dyd/assets/assertions.sh"

_setup() {
	TEMP_DIR=`mktemp -d 2>/dev/null || mktemp -d -t 'build-dir'`
}

_prepare() {
	cp -R "$SRC_DIR/dyd/assets/sample-garden/." "$TEMP_DIR"
	chmod -R 755 "$TEMP_DIR"
	printf 'true' > "$TEMP_DIR/dyd/roots/root-top/dyd/variants/os/darwin"
	cd "$TEMP_DIR"
	TEMP_DIR=$(pwd -P)
}

_test() {
	OUTPUT=$(dryad root ancestors dyd/roots/root-top --log-level="$DYD_LOG_LEVEL")
	EXPECTED=$(cat <<'EOF'
dyd/roots/root-base~os=linux
dyd/roots/root-mid~os=linux
dyd/roots/root-skip~os=linux
EOF
)
	if [ "$OUTPUT" != "$EXPECTED" ]; then
		echo "[ERROR] Fail: expected bare root ancestors output to be exact, sorted variant refs" 1>&2
		echo "$OUTPUT" 1>&2
		return 1
	fi

	OUTPUT_FS=$(dryad root ancestors dyd/roots/root-top~os=linux --log-level="$DYD_LOG_LEVEL")
	EXPECTED_FS=$(cat <<'EOF'
dyd/roots/root-base~os=linux
dyd/roots/root-mid~os=linux
EOF
)
	if [ "$OUTPUT_FS" != "$EXPECTED_FS" ]; then
		echo "[ERROR] Fail: expected filesystem-qualified root ref to select linux ancestors only" 1>&2
		echo "$OUTPUT_FS" 1>&2
		return 1
	fi

	OUTPUT_URL=$(dryad root ancestors 'dyd/roots/root-top?os=darwin' --log-level="$DYD_LOG_LEVEL")
	if [ "$OUTPUT_URL" != "dyd/roots/root-skip~os=linux" ]; then
		echo "[ERROR] Fail: expected URL-qualified root ref to select darwin ancestors only" 1>&2
		echo "$OUTPUT_URL" 1>&2
		return 1
	fi

	OUTPUT_FLAG=$(dryad root ancestors dyd/roots/root-top --variant=os=darwin,linux --log-level="$DYD_LOG_LEVEL")
	if [ "$OUTPUT_FLAG" != "$EXPECTED" ]; then
		echo "[ERROR] Fail: expected --variant selector to support multi-option unions" 1>&2
		echo "$OUTPUT_FLAG" 1>&2
		return 1
	fi

	OUTPUT_ABS=$(dryad root ancestors dyd/roots/root-top~os=linux --relative=false --log-level="$DYD_LOG_LEVEL")
	if ! printf '%s\n' "$OUTPUT_ABS" | grep -Fxq "$TEMP_DIR/dyd/roots/root-base~os=linux"; then
		echo "[ERROR] Fail: expected --relative=false to print absolute variant refs" 1>&2
		echo "$OUTPUT_ABS" 1>&2
		return 1
	fi

	if dryad root ancestors dyd/roots/root-top~os=linux --variant=os=darwin --log-level="$DYD_LOG_LEVEL" >"$TEMP_DIR/conflict.stdout" 2>"$TEMP_DIR/conflict.stderr"; then
		echo "[ERROR] Fail: expected command to reject selectors specified in both root_ref and --variant" 1>&2
		return 1
	fi
	if ! grep -Fq 'root ancestor selector specified in both root_ref and --variant' "$TEMP_DIR/conflict.stderr"; then
		echo "[ERROR] Fail: expected conflict error message for root_ref and --variant selectors" 1>&2
		cat "$TEMP_DIR/conflict.stderr" 1>&2
		return 1
	fi

	if dryad root ancestors '?os=linux' --log-level="$DYD_LOG_LEVEL" >"$TEMP_DIR/empty-path-url.stdout" 2>"$TEMP_DIR/empty-path-url.stderr"; then
		echo "[ERROR] Fail: expected command to reject URL-qualified root refs with an empty path" 1>&2
		return 1
	fi
	if ! grep -Fq 'missing root ref path' "$TEMP_DIR/empty-path-url.stderr"; then
		echo "[ERROR] Fail: expected missing root ref path error for URL-qualified root refs with an empty path" 1>&2
		cat "$TEMP_DIR/empty-path-url.stderr" 1>&2
		return 1
	fi

	if dryad root ancestors '~os=linux' --log-level="$DYD_LOG_LEVEL" >"$TEMP_DIR/empty-path-fs.stdout" 2>"$TEMP_DIR/empty-path-fs.stderr"; then
		echo "[ERROR] Fail: expected command to reject filesystem-qualified root refs with an empty path" 1>&2
		return 1
	fi
	if ! grep -Fq 'missing root ref path' "$TEMP_DIR/empty-path-fs.stderr"; then
		echo "[ERROR] Fail: expected missing root ref path error for filesystem-qualified root refs with an empty path" 1>&2
		cat "$TEMP_DIR/empty-path-fs.stderr" 1>&2
		return 1
	fi
}

_verify() {
	assert_directory_exists "$TEMP_DIR/dyd"
	assert_file_content_equals "$TEMP_DIR/dyd/type" "garden"
}

_teardown() {
	if [ -d "$TEMP_DIR" ]; then
		chmod -R 755 "$TEMP_DIR"
		rm -rf "$TEMP_DIR"
	fi
}

trap _teardown ERR EXIT
_setup
_prepare
_test
_verify
