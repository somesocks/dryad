#!/usr/bin/env bash
set -euf -o pipefail

SRC_DIR=$DYD_STEM
TEMP_DIR=''

. "$SRC_DIR/dyd/assets/assertions.sh"

_assert_linux_only() {
	local out_dir="$1"
	local log_path="$2"

	assert_directory_exists "$out_dir"
	assert_file_content_equals "$out_dir/amd64-linux" "ok"
	assert_file_content_equals "$out_dir/arm64-linux" "ok"

	if [ -f "$out_dir/amd64-darwin" ] || [ -f "$out_dir/arm64-darwin" ]; then
		echo "[ERROR] Fail: darwin variants should not run for selector arch=any+os=linux" 1>&2
		ls -1 "$out_dir" 1>&2
		return 1
	fi

	if ! grep -Fq "sprout run starting" "$log_path"; then
		echo "[ERROR] Fail: expected sprouts run logs to include a start line" 1>&2
		cat "$log_path" 1>&2
		return 1
	fi

	if ! grep -Fq "variant=" "$log_path"; then
		echo "[ERROR] Fail: expected sprouts run logs to include a variant field" 1>&2
		cat "$log_path" 1>&2
		return 1
	fi

	for variant in "arch=amd64+os=linux" "arch=arm64+os=linux"; do
		if ! grep -Fq "$variant" "$log_path"; then
			echo "[ERROR] Fail: expected sprouts run logs to include variant descriptor '$variant'" 1>&2
			cat "$log_path" 1>&2
			return 1
		fi
	done

	for variant in "arch=amd64+os=darwin" "arch=arm64+os=darwin"; do
		if grep -Fq "$variant" "$log_path"; then
			echo "[ERROR] Fail: expected sprouts run logs to exclude unmatched variant descriptor '$variant'" 1>&2
			cat "$log_path" 1>&2
			return 1
		fi
	done
}

_setup() {
	TEMP_DIR=`mktemp -d 2>/dev/null || mktemp -d -t 'build-dir'`
}

_prepare() {
	mkdir -p "$TEMP_DIR/dyd/sprouts"
	mkdir -p "$TEMP_DIR/dyd/heap/sprouts/root-top/dyd/dependencies"

	printf 'garden' > "$TEMP_DIR/dyd/type"
	printf 'sprout' > "$TEMP_DIR/dyd/heap/sprouts/root-top/dyd/type"

	for arch in amd64 arm64; do
		for os_name in linux darwin; do
			_create_variant_stem "$arch" "$os_name"
		done
	done

	ln -s "$TEMP_DIR/dyd/heap/sprouts/root-top" "$TEMP_DIR/dyd/sprouts/root-top"
	cd "$TEMP_DIR"
}

_create_variant_stem() {
	arch="$1"
	os_name="$2"
	stem="$TEMP_DIR/dyd/heap/stems/$arch-$os_name"

	mkdir -p "$stem/dyd/commands" "$stem/dyd/traits"
	printf '%s' "$arch" > "$stem/dyd/traits/arch"
	printf '%s' "$os_name" > "$stem/dyd/traits/os"
	cat > "$stem/dyd/commands/dyd-stem-run" <<'EOF'
#!/usr/bin/env bash
set -euf -o pipefail

arch="$(cat "$DYD_STEM/dyd/traits/arch")"
os_name="$(cat "$DYD_STEM/dyd/traits/os")"

out_dir="$DYD_GARDEN/dyd/heap/sprouts-run-03--qualified-stdin-refs"
mkdir -p "$out_dir"
printf "ok\n" > "$out_dir/$arch-$os_name"
EOF
	chmod 755 "$stem/dyd/commands/dyd-stem-run"
	ln -s "$stem" "$TEMP_DIR/dyd/heap/sprouts/root-top/dyd/dependencies/stem~arch=$arch+os=$os_name"
}

_test() {
	fs_log_path="$TEMP_DIR/sprouts-run-filesystem.log"
	printf '%s\n' 'dyd/sprouts/root-top~arch=any+os=linux' \
		| dryad sprouts run --from-stdin --log-level="$DYD_LOG_LEVEL" >"$fs_log_path" 2>&1
	cp -R "$TEMP_DIR/dyd/heap/sprouts-run-03--qualified-stdin-refs" "$TEMP_DIR/fs-out"

	rm -rf "$TEMP_DIR/dyd/heap/sprouts-run-03--qualified-stdin-refs"

	url_log_path="$TEMP_DIR/sprouts-run-url.log"
	printf '%s\n' 'dyd/sprouts/root-top?arch=any&os=linux' \
		| dryad sprouts run --from-stdin --log-level="$DYD_LOG_LEVEL" >"$url_log_path" 2>&1
	cp -R "$TEMP_DIR/dyd/heap/sprouts-run-03--qualified-stdin-refs" "$TEMP_DIR/url-out"

	rm -rf "$TEMP_DIR/dyd/heap/sprouts-run-03--qualified-stdin-refs"

	empty_log_path="$TEMP_DIR/sprouts-run-empty.log"
	: | dryad sprouts run --from-stdin --log-level="$DYD_LOG_LEVEL" >"$empty_log_path" 2>&1

	set +e
	duplicate_output=$(
		printf '%s\n' 'dyd/sprouts/root-top~arch=any+os=linux' \
			| dryad sprouts run --from-stdin --variant="arch=amd64+os=linux" --log-level="$DYD_LOG_LEVEL" 2>&1
	)
	duplicate_status=$?

	overspecified_output=$(dryad sprouts run --variant="cpu=x86" --log-level="$DYD_LOG_LEVEL" 2>&1)
	overspecified_status=$?

	wrong_option_output=$(dryad sprouts run --variant="arch=s390x" --log-level="$DYD_LOG_LEVEL" 2>&1)
	wrong_option_status=$?

	inherit_output=$(dryad sprouts run --variant="arch=inherit" --log-level="$DYD_LOG_LEVEL" 2>&1)
	inherit_status=$?
	set -e
}

_verify() {
	out_dir="$TEMP_DIR/dyd/heap/sprouts-run-03--qualified-stdin-refs"

	_assert_linux_only "$TEMP_DIR/fs-out" "$TEMP_DIR/sprouts-run-filesystem.log"
	_assert_linux_only "$TEMP_DIR/url-out" "$TEMP_DIR/sprouts-run-url.log"

	if [ -d "$out_dir" ]; then
		echo "[ERROR] Fail: expected empty stdin to run no sprouts" 1>&2
		ls -1 "$out_dir" 1>&2 || true
		return 1
	fi

	if [ "$duplicate_status" -eq 0 ]; then
		echo "[ERROR] Fail: expected sprouts run to fail when selector is specified in both stdin sprout_ref and --variant" 1>&2
		return 1
	fi

	if ! printf '%s' "$duplicate_output" | grep -Fq "sprouts run selector specified in both stdin sprout_ref and --variant"; then
		echo "[ERROR] Fail: expected duplicate selector error for sprouts run" 1>&2
		printf '%s\n' "$duplicate_output" 1>&2
		return 1
	fi

	if [ "$overspecified_status" -eq 0 ]; then
		echo "[ERROR] Fail: expected over-specified variant dimension to fail" 1>&2
		return 1
	fi
	if ! printf '%s' "$overspecified_output" | grep -Fq "over-specified sprout run variant dimension: cpu"; then
		echo "[ERROR] Fail: expected over-specified variant dimension error" 1>&2
		printf '%s\n' "$overspecified_output" 1>&2
		return 1
	fi

	if [ "$wrong_option_status" -eq 0 ]; then
		echo "[ERROR] Fail: expected wrongly-specified variant option to fail" 1>&2
		return 1
	fi
	if ! printf '%s' "$wrong_option_output" | grep -Fq "wrongly-specified sprout run variant option: arch=s390x"; then
		echo "[ERROR] Fail: expected wrongly-specified variant option error" 1>&2
		printf '%s\n' "$wrong_option_output" 1>&2
		return 1
	fi

	if [ "$inherit_status" -eq 0 ]; then
		echo "[ERROR] Fail: expected inherit variant selector to fail" 1>&2
		return 1
	fi
	if ! printf '%s' "$inherit_output" | grep -Fq "inherit option is not supported for sprout run variant selectors: arch"; then
		echo "[ERROR] Fail: expected inherit variant selector error" 1>&2
		printf '%s\n' "$inherit_output" 1>&2
		return 1
	fi
}

_teardown() {
	if [ -d "$TEMP_DIR" ]; then
		chmod -R 755 "$TEMP_DIR"
		rm -rf "$TEMP_DIR"
	fi
}

trap _teardown ERR EXIT
_setup
_prepare
_test
_verify
