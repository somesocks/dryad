#!/usr/bin/env bash
set -euf -o pipefail

TEMP_DIR=''

assert_file_content_equals() { actual=$(cat "$1"); if [ "$actual" != "$2" ]; then echo "[ERROR] Fail: expected $1 to contain ($2), got ($actual)" 1>&2; return 1; fi; }

_setup() {
	TEMP_DIR=`mktemp -d 2>/dev/null || mktemp -d -t 'build-dir'`
	mkdir -p "$TEMP_DIR/dyd/roots" "$TEMP_DIR/dyd/external" "$TEMP_DIR/dyd/roots/external"
	printf 'garden' > "$TEMP_DIR/dyd/type"
	printf 'original' > "$TEMP_DIR/dyd/external/data.txt"
	printf 'unpinned' > "$TEMP_DIR/dyd/roots/external/data.txt"
	cd "$TEMP_DIR"
}

_create_root() {
	root_name="$1"
	mkdir -p "dyd/roots/$root_name/dyd/commands" "dyd/roots/$root_name/dyd/requirements"
	printf 'root' > "dyd/roots/$root_name/dyd/type"
	printf '%s' 'file:../../../../external/data.txt?as=dyd/assets/copied/value.txt&optional=true' > "dyd/roots/$root_name/dyd/requirements/data"
	cat > "dyd/roots/$root_name/dyd/commands/dyd-root-build" <<'EOF'
#!/usr/bin/env sh
set -eu
mkdir -p "$DYD_BUILD/dyd/assets"
cat "$DYD_STEM/dyd/dependencies/data/dyd/assets/copied/value.txt" > "$DYD_BUILD/dyd/assets/value.txt"
EOF
	chmod +x "dyd/roots/$root_name/dyd/commands/dyd-root-build"
}

_test() {
	_create_root root-source
	dryad root copy dyd/roots/root-source dyd/roots/nested/root-copy --log-level=info > /dev/null 2>&1
	assert_file_content_equals "$TEMP_DIR/dyd/roots/nested/root-copy/dyd/requirements/data" 'file:../../../../../external/data.txt?as=dyd/assets/copied/value.txt&optional=true'
	dryad root build dyd/roots/nested/root-copy --log-level=info > /dev/null 2>&1
	assert_file_content_equals "$TEMP_DIR/dyd/sprouts/nested/root-copy/dyd/dependencies/stem/dyd/assets/value.txt" 'original'

	dryad root copy dyd/roots/root-source dyd/roots/nested/root-copy-unpin --unpin --log-level=info > /dev/null 2>&1
	assert_file_content_equals "$TEMP_DIR/dyd/roots/nested/root-copy-unpin/dyd/requirements/data" 'file:../../../../external/data.txt?as=dyd/assets/copied/value.txt&optional=true'
	dryad root build dyd/roots/nested/root-copy-unpin --log-level=info > /dev/null 2>&1
	assert_file_content_equals "$TEMP_DIR/dyd/sprouts/nested/root-copy-unpin/dyd/dependencies/stem/dyd/assets/value.txt" 'unpinned'
}

_teardown() { if [ -d "$TEMP_DIR" ]; then chmod -R 755 "$TEMP_DIR"; rm -rf "$TEMP_DIR"; fi; }
trap _teardown ERR EXIT
_setup
_test
