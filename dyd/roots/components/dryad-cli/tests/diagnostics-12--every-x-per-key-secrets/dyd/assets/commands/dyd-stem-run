#!/usr/bin/env bash
set -euf -o pipefail

SRC_DIR=$DYD_STEM
TEMP_DIR=''

. "$SRC_DIR/dyd/assets/assertions.sh"

_setup() {
  TEMP_DIR=`mktemp -d 2>/dev/null || mktemp -d -t 'build-dir'`
}

_prepare() {
  cp -R "$SRC_DIR/dyd/assets/sample-garden/." "$TEMP_DIR"
  chmod -R 755 "$TEMP_DIR"
  cd "$TEMP_DIR"
}

_inode_of() {
  local path="$1"
  if stat -c %i "$path" >/dev/null 2>&1; then
    stat -c %i "$path"
  else
    stat -f %i "$path"
  fi
}

_test() {
  local success_every100_log="$TEMP_DIR/build-every-x-per-key-100.log"
  local success_every2_log="$TEMP_DIR/build-every-x-per-key-2.log"
  local secret_1
  local secret_2
  local inode_1
  local inode_2
  local heap_secret_file

  every100_cfg='json:{"version":1,"seed":1,"rules":[{"id":"inject-every100-per-key","op":"os.link","key":"*","when":{"mode":"every_x_per_key","x":100},"action":{"type":"error","error":"EMLINK"}}]}'
  dryad garden wipe --log-level="$DYD_LOG_LEVEL"
  if ! DYD_DIAG="$every100_cfg" dryad root build "dyd/roots/root-01" --scope=none --log-level="$DYD_LOG_LEVEL" >"$success_every100_log" 2>&1; then
    echo "[ERROR] Fail: expected secret build to succeed with every_x_per_key x=100" 1>&2
    cat "$success_every100_log" 1>&2
    return 1
  fi

  every2_cfg='json:{"version":1,"seed":1,"rules":[{"id":"inject-every2-per-key","op":"os.link","key":"*","when":{"mode":"every_x_per_key","x":2},"action":{"type":"error","error":"EMLINK"}}]}'
  dryad garden wipe --log-level="$DYD_LOG_LEVEL"
  if ! DYD_DIAG="$every2_cfg" dryad root build "dyd/roots/root-01" --scope=none --log-level="$DYD_LOG_LEVEL" >"$success_every2_log" 2>&1; then
    echo "[ERROR] Fail: expected secret build to recover from every_x_per_key x=2" 1>&2
    cat "$success_every2_log" 1>&2
    return 1
  fi

  secret_1="$TEMP_DIR/dyd/sprouts/root-01/dyd/dependencies/stem/dyd/secrets/test-secret-01"
  secret_2="$TEMP_DIR/dyd/sprouts/root-01/dyd/dependencies/stem/dyd/secrets/test-dir-01/test-secret-02"

  assert_file_content_equals "$secret_1" "same-secret"
  assert_file_content_equals "$secret_2" "same-secret"

  inode_1="$(_inode_of "$secret_1")"
  inode_2="$(_inode_of "$secret_2")"
  if [ "$inode_1" != "$inode_2" ]; then
    echo "[ERROR] Fail: expected repeated secret content to keep sharing an inode after recovery" 1>&2
    return 1
  fi

  heap_secret_file=$(find "$TEMP_DIR/dyd/heap/secrets" -maxdepth 1 -type f -inum "$inode_1" -print -quit)
  if [ -z "$heap_secret_file" ]; then
    echo "[ERROR] Fail: expected recovered secret inode to remain hardlinked from heap/secrets" 1>&2
    return 1
  fi

  if find "$TEMP_DIR/dyd/heap/secrets" -maxdepth 1 -type f -name '.tmp-*' | grep -q .; then
    echo "[ERROR] Fail: expected no temp files left in heap/secrets after recovery" 1>&2
    find "$TEMP_DIR/dyd/heap/secrets" -maxdepth 1 -type f -name '.tmp-*' 1>&2
    return 1
  fi
}

_verify() {
  assert_directory_exists "$TEMP_DIR/dyd/sprouts/root-01"
  assert_file_exists "$TEMP_DIR/dyd/sprouts/root-01/dyd/fingerprint"
}

_teardown() {
  if [ -d "$TEMP_DIR" ]; then
    chmod -R 755 "$TEMP_DIR"
    rm -rf "$TEMP_DIR"
  fi
}

trap _teardown ERR EXIT
_setup
_prepare
_test
_verify
